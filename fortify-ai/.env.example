# ─────────────────────────────────────────────────────────────────────────────
# FortifyAI — Environment Variables
# Copy this file to .env and fill in your values.
# Never commit .env to version control.
# ─────────────────────────────────────────────────────────────────────────────

# ── Fortify SSC ──────────────────────────────────────────────────────────────
# Base URL of your Fortify SSC instance (no trailing slash)
FORTIFY_BASE_URL=https://your-instance.fortify.com

# Fortify SSC API token (generate under Administration → Token Management)
FORTIFY_API_TOKEN=your-fortify-api-token-here

# ── GitHub ───────────────────────────────────────────────────────────────────
# Personal access token with repo + pull_request scopes
GITHUB_TOKEN=ghp_your_token_here

# Target repository in owner/repo format
GITHUB_REPO=your-org/your-repo

# ── Project / Tooling ────────────────────────────────────────────────────────
# Absolute path to the Maven project root that FortifyAI will remediate
PROJECT_PATH=/path/to/your/maven/project

# Absolute path to the ADR (Automated Dependency Remediation) script
ADR_PATH=/path/to/adr.py

# Absolute path to the japicmp fat-jar for API diff analysis
JAPICMP_JAR_PATH=/path/to/japicmp-0.23.0-jar-with-dependencies.jar

# ── GCP / Vertex AI ──────────────────────────────────────────────────────────
# GCP project ID where Vertex AI is enabled
GCP_PROJECT=your-gcp-project-id

# GCP region for Vertex AI (default: us-central1)
GCP_LOCATION=us-central1

# ── Pipeline Behaviour ────────────────────────────────────────────────────────
# Max AI code-fix retry attempts before escalating (default: 3)
MAX_RETRIES=3

# Prefix for JIRA IDs used in branch names and commit messages (default: FORTIFY)
JIRA_ID_PREFIX=FORTIFY

# Comma-separated GitHub usernames for auto-reviewer assignment on high-confidence PRs
# Leave empty to skip auto-assignment
REVIEWERS=

# Directory where ADR PDF reports and FortifyAI logs are written (default: /tmp/fortifyai)
ADR_OUTPUT_DIR=/tmp/fortifyai
