# ══════════════════════════════════════════════════════════════════════════════
# SonarAI — Environment Variables  (GCS-only stateless deployment, no Redis)
# ══════════════════════════════════════════════════════════════════════════════
# Applies to BOTH deployments: API (uvicorn api:app) and Worker (python worker.py).
# The worker runs the pipeline, so it needs the full set.
#
# Values are loaded from the real process environment (K8s ConfigMap/Secret,
# Docker env, shell export). No .env file is read by the app itself.
# ══════════════════════════════════════════════════════════════════════════════


# ──────────────────────────────────────────────────────────────────────────────
# MANDATORY — pods fail to start (or first request fails) without these
# ──────────────────────────────────────────────────────────────────────────────

# GCS bucket holding ALL mutable state:
#   runs/            — run documents (pipeline status/results)
#   jobs/pending/    — job queue polled by worker.py
#   state/           — issues.json + config.json (settings overrides)
#   reports/         — uploaded sonar report (durable source of truth)
#   escalations/     — escalation markdown files
GCS_BUCKET=

# GCP project ID — used by the GCS client and Vertex AI.
# (Required Pydantic field: gcp_project)
GCP_PROJECT=

# GitHub personal access token — repo clone + PR creation.
# (Required Pydantic field: github_token)  →  store as K8s SECRET
GITHUB_TOKEN=


# ──────────────────────────────────────────────────────────────────────────────
# OPTIONAL — SECRETS (store as K8s Secret; defaults shown)
# ──────────────────────────────────────────────────────────────────────────────

# SonarQube/SonarCloud API token. Can also be set from the Settings page,
# but only this env var survives pod restarts (tokens are never written to GCS).
SONAR_TOKEN=

# LangSmith tracing — leave empty to disable tracing entirely.
LANGSMITH_API_KEY=


# ──────────────────────────────────────────────────────────────────────────────
# OPTIONAL — GCP / VERTEX AI
# ──────────────────────────────────────────────────────────────────────────────

GCP_LOCATION=us-central1
VERTEX_MODEL=gemini-2.5-flash
VERTEX_FALLBACK_MODEL=gemini-1.5-pro-002
EMBEDDING_MODEL=text-embedding-005
MAX_TOKENS=8192


# ──────────────────────────────────────────────────────────────────────────────
# OPTIONAL — INTEGRATIONS
# ──────────────────────────────────────────────────────────────────────────────

# Override for GitHub Enterprise
GITHUB_BASE_URL=https://api.github.com

SONAR_HOST_URL=https://sonarcloud.io

LANGSMITH_PROJECT=sonar-ai
LANGSMITH_ENDPOINT=https://api.smith.langchain.com


# ──────────────────────────────────────────────────────────────────────────────
# OPTIONAL — PIPELINE BEHAVIOUR
# ──────────────────────────────────────────────────────────────────────────────

# Max issues to process per run (0 = no limit)
MAX_ISSUES=1

# Max LLM fix retry loops per issue
MAX_CRITIC_RETRIES=3

# Agent temperatures
PLANNER_TEMPERATURE=0.1
GENERATOR_TEMPERATURE=0.3

# Confidence routing:  >= HIGH → auto PR,  >= MEDIUM → draft PR,  else escalate
CONFIDENCE_HIGH_THRESHOLD=0.8
CONFIDENCE_MEDIUM_THRESHOLD=0.5

# Build/test timeouts (seconds)
COMPILE_TIMEOUT=120
TEST_TIMEOUT=180

# Worker-local scratch directories (default: under system temp dir)
# CLONE_DIR=/tmp/sonar-ai-repos
# ESCALATION_DIR=escalations        # synced to GCS escalations/ after each run

# Parallel issue processing (LangGraph Send API)
PARALLEL_ISSUES=false
MAX_PARALLEL_WORKERS=3


# ──────────────────────────────────────────────────────────────────────────────
# OPTIONAL — RAG / CHROMADB
# ──────────────────────────────────────────────────────────────────────────────

ENABLE_RAG=true
RAG_TOP_K=3
# Worker-local vector store path (default: under system temp dir)
# CHROMA_PERSIST_DIR=/tmp/sonar-ai-chroma


# ──────────────────────────────────────────────────────────────────────────────
# OPTIONAL — SONAR RESCAN VERIFICATION
# ──────────────────────────────────────────────────────────────────────────────

# Query Sonar API after a fix to verify the rule no longer fires
ENABLE_SONAR_RESCAN=false
# Max seconds to wait for the Sonar analysis to complete
SONAR_RESCAN_TIMEOUT=300


# ──────────────────────────────────────────────────────────────────────────────
# NOTES
# ──────────────────────────────────────────────────────────────────────────────
# • REDIS_URL is REMOVED — delete it from any existing ConfigMap.
#
# • GCP auth is not an env var by default: both pods use Application Default
#   Credentials. On GKE, bind the pod's service account via Workload Identity
#   to a GSA with roles/storage.objectAdmin on GCS_BUCKET + Vertex AI access.
#   Outside GKE, set:
#     GOOGLE_APPLICATION_CREDENTIALS=/path/to/service-account-key.json
#
# • Runtime overrides: these fields can also be changed live from the Settings
#   page and are persisted to gs://$GCS_BUCKET/state/config.json, which
#   overrides the env-var defaults on every read:
#     gcp_project, vertex_model, embedding_model, sonar_host_url, max_issues,
#     max_tokens, rag_top_k, max_critic_retries, planner_temperature,
#     generator_temperature, confidence thresholds, chroma_persist_dir.
#   Tokens (GITHUB_TOKEN, SONAR_TOKEN) are never persisted to GCS.
#
# • Run history expiry: the old 7-day Redis TTL is gone. To restore it, add a
#   GCS lifecycle rule on the runs/ prefix (age > 7 days → Delete).
# ══════════════════════════════════════════════════════════════════════════════